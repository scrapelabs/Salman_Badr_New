# MatchMiner - local environment configuration.
#
# Copy this file to ".env" and fill in your own values.
# install.bat creates .env from this template automatically if it is missing.
# .env is git-ignored, so your real credentials are never committed.

# --- PostgreSQL connection -------------------------------------------------
# Full connection URL used by Django (parsed by dj-database-url).
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:postgres@localhost:5432/matchminer

# --- Django ----------------------------------------------------------------
# Secret key for cryptographic signing. Use a long random string for real use.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Verbose error pages. Keep True for local development; set False in production.
DJANGO_DEBUG=True

# Local HTTP development. Set True when serving over http://localhost:8000 so the
# session/CSRF cookies are sent over plain HTTP (Secure cookies are not), which
# is required for login to work locally. Leave unset/False in hosted HTTPS envs.
DJANGO_LOCAL_HTTP=True

# --- Scraper credentials ---------------------------------------------------
# Ioncourt (college dual matches) logs into api.ioncourt.com with a phone number
# + password. Fill these in to enable that scraper; leave blank and the Ioncourt
# run fails honestly (every other scraper is unaffected). Never commit real
# values — .env is git-ignored.
IONCOURT_PHONE=
IONCOURT_PASSWORD=
